{
    "PROJECT_NAME"              : "PrismCommander",
    "PROJECT_DESCRIPTION"       : "Terminal file-manager / commander built on tUilKit and Chromaspace",
    "AUTHOR"                    : "Daniel Austin <the.potato.gnome@gmail.com>",
    "VERSION"                   : "0.3.0",

    "CONFIG_FILES"              : {
        "COLOURS"               : "config/COLOURS.json",
        "BORDER_PATTERNS"       : "config/BORDER_PATTERNS.json",
        "GLOBAL_CONFIG"         : "config/GLOBAL_CONFIG.json"
    },

    "LOG_FILES"                 : {
        "SESSION"               : "logs/RUNTIME.log",
        "MASTER"                : "logs/MASTER.log",
        "ERROR"                 : "logs/ERROR.log",
        "FS"                    : "logs/FS.log",
        "INIT"                  : "logs/INIT.log",
        "DEBUG"                 : "logs/DEBUG.log",
        "WARNING"               : "logs/WARNING.log"
    },

    "LOG_CATEGORIES"            : {
        "default"   : ["MASTER", "SESSION"],
        "error"     : ["ERROR", "SESSION", "MASTER"],
        "fs"        : ["MASTER", "SESSION", "FS"],
        "init"      : ["INIT", "SESSION", "MASTER"],
        "debug"     : ["DEBUG", "SESSION"],
        "warning"   : ["WARNING", "SESSION", "MASTER"],
        "all"       : ["MASTER", "SESSION", "ERROR", "FS", "INIT", "DEBUG", "WARNING"]
    },

    "time_stamp_format"         : "%Y%m%d_%H%M%S",
    "time_stamp_logs"           : true,
    "time_stamp_test_logs"      : true,
    "time_stamp_files"          : false,
    "time_stamp_test_files"     : true,
    "time_stamp_folders"        : false,
    "time_stamp_test_folders"   : true
}
